# Backend environment variables. Copy to .env and fill in real values.
# Do not commit real secrets.

# Supabase project URL (same project as the frontend).
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/publishable key. The backend forwards the caller's JWT so
# Row Level Security enforces ownership — no service-role key needed.
SUPABASE_ANON_KEY=

# Allowed CORS origin for the Next.js frontend.
FRONTEND_ORIGIN=http://localhost:3000
