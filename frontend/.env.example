# Supabase — copy this file to .env.local and fill in your project values.
# Found in the Supabase dashboard under Project Settings → API.
# Both are safe to expose to the browser (the anon key is gated by Row Level Security).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# FastAPI backend base URL. Defaults to http://localhost:8000 in dev if unset.
NEXT_PUBLIC_API_URL=
